"""
AI / LLM Features router powered by OpenAI.

Endpoints:
  POST /api/ai/match-candidates      – rank candidates vs a job description
  POST /api/ai/screen-resume         – score one resume against a job
  POST /api/ai/generate-job-description – write a polished JD
  POST /api/ai/interview-questions   – generate role-specific questions
  POST /api/ai/chat                  – retention & hiring chatbot (multi-turn)
"""

import uuid
from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select

from app.database import get_db
from app.models import Job, ChatSession, ChatMessage
from app.schemas import (
    CandidateMatchRequest, CandidateMatchResponse, CandidateMatchResult,
    ResumeScreenRequest, ResumeScreenResponse,
    JobDescriptionRequest, JobDescriptionResponse,
    InterviewQuestionRequest, InterviewQuestionResponse,
    ChatMessageIn, ChatMessageOut,
)
from app.llm.openai_service import (
    match_candidates,
    screen_resume,
    generate_job_description,
    generate_interview_questions,
    retention_chat,
)

router = APIRouter()


# ── 1. Candidate Matching ──────────────────────────────────────────────────────

@router.post("/match-candidates", response_model=CandidateMatchResponse)
async def api_match_candidates(payload: CandidateMatchRequest):
    """
    Rank a list of candidate profiles against a job description using AI.
    Returns each candidate's fit score (0-100), strengths, and gaps.
    """
    if not payload.candidate_profiles:
        raise HTTPException(status_code=400, detail="At least one candidate profile required")

    results = await match_candidates(
        payload.job_description,
        payload.candidate_profiles,
    )
    return CandidateMatchResponse(
        results=[CandidateMatchResult(**r) for r in results]
    )


# ── 2. Resume Screening ────────────────────────────────────────────────────────

@router.post("/screen-resume", response_model=ResumeScreenResponse)
async def api_screen_resume(
    payload: ResumeScreenRequest,
    db: AsyncSession = Depends(get_db),
):
    """
    AI-screen a resume against a stored job's description.
    Returns a score (0-100), qualitative feedback, and recommendation flag.
    """
    job = await db.get(Job, payload.job_id)
    if not job:
        raise HTTPException(status_code=404, detail="Job not found")
    if not job.description:
        raise HTTPException(status_code=400, detail="Job has no description to screen against")

    result = await screen_resume(job.description, payload.resume_text)
    return ResumeScreenResponse(**result)


# ── 3. Job Description Generator ──────────────────────────────────────────────

@router.post("/generate-job-description", response_model=JobDescriptionResponse)
async def api_generate_jd(payload: JobDescriptionRequest):
    """
    Generate a polished, inclusive job description for the Building Materials
    career board using AI.
    """
    jd = await generate_job_description(
        title=payload.title,
        industry=payload.industry.value,
        location=payload.location,
        key_responsibilities=payload.key_responsibilities or "",
        required_skills=payload.required_skills or "",
        salary_range=payload.salary_range or "",
    )
    return JobDescriptionResponse(job_description=jd)


# ── 4. Interview Questions ─────────────────────────────────────────────────────

@router.post("/interview-questions", response_model=InterviewQuestionResponse)
async def api_interview_questions(payload: InterviewQuestionRequest):
    """
    Generate role-specific, behaviour-based interview questions using AI.
    """
    questions = await generate_interview_questions(
        job_title=payload.job_title,
        industry=payload.industry.value,
        level=payload.level,
        num_questions=payload.num_questions,
    )
    return InterviewQuestionResponse(questions=questions)


# ── 5. Retention / Hiring Chatbot ──────────────────────────────────────────────

@router.post("/chat", response_model=ChatMessageOut)
async def api_chat(
    payload: ChatMessageIn,
    db: AsyncSession = Depends(get_db),
):
    """
    Multi-turn AI chatbot for retention & hiring advice.
    Pass a session_id to continue an existing conversation.
    A new UUID session_id is created if one doesn't exist.
    Topic: 'retention' | 'hiring' | 'general'
    """
    # Get or create session
    result = await db.execute(
        select(ChatSession).where(ChatSession.session_id == payload.session_id)
    )
    session = result.scalar_one_or_none()

    if not session:
        session = ChatSession(
            session_id=payload.session_id or str(uuid.uuid4()),
            topic=payload.topic,
        )
        db.add(session)
        await db.flush()

    # Load conversation history
    history_result = await db.execute(
        select(ChatMessage)
        .where(ChatMessage.session_id == session.id)
        .order_by(ChatMessage.created_at)
    )
    history = [
        {"role": msg.role, "content": msg.content}
        for msg in history_result.scalars().all()
    ]

    # Call OpenAI
    reply = await retention_chat(history, payload.message)

    # Persist both turns
    db.add(ChatMessage(session_id=session.id, role="user",      content=payload.message))
    db.add(ChatMessage(session_id=session.id, role="assistant", content=reply))
    await db.commit()

    return ChatMessageOut(session_id=session.session_id, reply=reply)
