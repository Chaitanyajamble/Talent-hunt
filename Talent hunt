from app.database import Base


# ── Enums ─────────────────────────────────────────────────────────────────────

class IndustryType(str, enum.Enum):
    building_materials = "building_materials"
    life_sciences      = "life_sciences"
    industrial         = "industrial"
    consumer_products  = "consumer_products"
    technology         = "technology"


class ServiceType(str, enum.Enum):
    contingency_recruitment     = "contingency_recruitment"
    recruitment_process_solutions = "recruitment_process_solutions"
    digital_transformation      = "digital_transformation"
    retain_or_refund            = "retain_or_refund"
    retention_solutions         = "retention_solutions"


class JobStatus(str, enum.Enum):
    open   = "open"
    filled  = "filled"
    closed  = "closed"


class LeadServiceChoice(str, enum.Enum):
    membership_program            = "membership_program"
    contingency_recruitment       = "contingency_recruitment"
    recruitment_process_solutions = "recruitment_process_solutions"
    retain_or_refund              = "retain_or_refund"
    digital_transformation        = "digital_transformation"


# ── Industry ──────────────────────────────────────────────────────────────────

class Industry(Base):
    __tablename__ = "industries"

    id          = Column(Integer, primary_key=True, index=True)
    name        = Column(String(120), nullable=False)
    slug        = Column(String(60), unique=True, nullable=False)
    type        = Column(SAEnum(IndustryType), nullable=False)
    description = Column(Text)
    created_at  = Column(DateTime, default=datetime.utcnow)

    jobs = relationship("Job", back_populates="industry")


# ── Service ───────────────────────────────────────────────────────────────────

class Service(Base):
    __tablename__ = "services"

    id          = Column(Integer, primary_key=True, index=True)
    name        = Column(String(120), nullable=False)
    slug        = Column(String(60), unique=True, nullable=False)
    type        = Column(SAEnum(ServiceType), nullable=False)
    description = Column(Text)
    features    = Column(Text)   # JSON-encoded list of bullet features
    created_at  = Column(DateTime, default=datetime.utcnow)


# ── 4-Step Process ────────────────────────────────────────────────────────────

class ProcessStep(Base):
    __tablename__ = "process_steps"

    id          = Column(Integer, primary_key=True, index=True)
    step_number = Column(Integer, nullable=False)        # 1-4
    name        = Column(String(60), nullable=False)     # HUNT / ASSESS / MANAGE / GROW
    tagline     = Column(String(255))
    description = Column(Text)


# ── Job Board ─────────────────────────────────────────────────────────────────

class Job(Base):
    __tablename__ = "jobs"

    id              = Column(Integer, primary_key=True, index=True)
    title           = Column(String(200), nullable=False)
    company         = Column(String(200))
    location        = Column(String(200))
    industry_id     = Column(Integer, ForeignKey("industries.id"), nullable=True)
    service_type    = Column(SAEnum(ServiceType))
    description     = Column(Text)
    requirements    = Column(Text)
    salary_range    = Column(String(100))
    status          = Column(SAEnum(JobStatus), default=JobStatus.open)
    is_featured     = Column(Boolean, default=False)
    created_at      = Column(DateTime, default=datetime.utcnow)
    updated_at      = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)

    industry     = relationship("Industry", back_populates="jobs")
    applications = relationship("JobApplication", back_populates="job")


class JobApplication(Base):
    __tablename__ = "job_applications"

    id           = Column(Integer, primary_key=True, index=True)
    job_id       = Column(Integer, ForeignKey("jobs.id"), nullable=False)
    full_name    = Column(String(200), nullable=False)
    email        = Column(String(200), nullable=False)
    phone        = Column(String(50))
    resume_text  = Column(Text)          # parsed resume content
    cover_letter = Column(Text)
    ai_score     = Column(Integer)       # 0-100, filled by AI screening
    ai_feedback  = Column(Text)          # AI screening summary
    created_at   = Column(DateTime, default=datetime.utcnow)

    job = relationship("Job", back_populates="applications")


# ── Contact / Lead Form ───────────────────────────────────────────────────────

class Lead(Base):
    __tablename__ = "leads"

    id             = Column(Integer, primary_key=True, index=True)
    full_name      = Column(String(200), nullable=False)
    email          = Column(String(200), nullable=False)
    phone          = Column(String(50))
    company        = Column(String(200))
    service_choice = Column(SAEnum(LeadServiceChoice))
