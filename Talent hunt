# ── Applications ──────────────────────────────────────────────────────────────

async def _run_ai_screening(application_id: int, job_description: str, resume_text: str):
    """Background task: AI-screen a resume and update the application record."""
    from app.database import AsyncSessionLocal
    async with AsyncSessionLocal() as db:
        app_obj = await db.get(JobApplication, application_id)
        if not app_obj:
            return
        result = await screen_resume(job_description, resume_text)
        app_obj.ai_score    = result.get("score", 0)
        app_obj.ai_feedback = result.get("feedback", "")
        await db.commit()


@router.post("/{job_id}/apply", response_model=ApplicationOut, status_code=201)
async def apply_for_job(
    job_id: int,
    payload: ApplicationCreate,
    background_tasks: BackgroundTasks,
    db: AsyncSession = Depends(get_db),
):
    job = await db.get(Job, job_id)
    if not job:
        raise HTTPException(status_code=404, detail="Job not found")
    if job.status != JobStatus.open:
        raise HTTPException(status_code=400, detail="This position is no longer accepting applications")

    application = JobApplication(job_id=job_id, **payload.model_dump())
    db.add(application)
    await db.commit()
    await db.refresh(application)

    # Fire AI screening in the background
    if job.description:
        background_tasks.add_task(
            _run_ai_screening,
            application.id,
            job.description,
            payload.resume_text,
        )

    return application


@router.get("/{job_id}/applications", response_model=list[ApplicationOut])
async def list_applications(job_id: int, db: AsyncSession = Depends(get_db)):
    result = await db.execute(
        select(JobApplication)
        .where(JobApplication.job_id == job_id)
        .order_by(JobApplication.ai_score.desc())
    )
    return result.scalars().all()


@router.get("/{job_id}/applications/{app_id}", response_model=ApplicationOut)
async def get_application(
    job_id: int, app_id: int, db: AsyncSession = Depends(get_db)
):
    app_obj = await db.get(JobApplication, app_id)
    if not app_obj or app_obj.job_id != job_id:
        raise HTTPException(status_code=404, detail="Application not found")
    return app_obj
