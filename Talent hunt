"""
LLM Service – powers all AI features for TalentHunt:
"""

import os
import json
import logging
from typing import Any

from openai import AsyncOpenAI

logger = logging.getLogger(__name__)

client = AsyncOpenAI(api_key=os.getenv("OPENAI_API_KEY"))

MODEL = os.getenv("OPENAI_MODEL", "gpt-4o-mini")

# System personas
_RECRUITER_SYSTEM = (
    "You are an expert recruitment consultant at TalentHunt Inc., "
    "North America's preferred Building Materials recruiter. "
    "You specialise in talent acquisition across Building Materials, "
    "Life Sciences, Industrial/Manufacturing, Consumer Products, and Technology. "
    "Always respond concisely, professionally, and with data-driven insights."
)

_RETENTION_SYSTEM = (
    "You are TalentHunt's Retention Coach – an AI assistant that helps "
    "businesses improve employee retention. You draw on TalentHunt's "
    "neuroscience-backed methodology and industry best practices. "
    "Ask clarifying questions when needed and provide actionable advice."
)


# ── Helper ─────────────────────────────────────────────────────────────────────

async def _chat(system: str, user: str, json_mode: bool = False) -> str:
    """Single-turn chat completion helper."""
    kwargs: dict[str, Any] = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user",   "content": user},
        ],
        "temperature": 0.4,
        "max_tokens": 1500,
    }
    if json_mode:
        kwargs["response_format"] = {"type": "json_object"}

    response = await client.chat.completions.create(**kwargs)
    return response.choices[0].message.content.strip()


# ── 1. Candidate Matching ──────────────────────────────────────────────────────

async def match_candidates(job_description: str, profiles: list[str]) -> list[dict]:
    """
    Score and rank a list of candidate profiles against a job description.
    Returns a list of dicts with keys: candidate_index, score, summary,
    strengths, gaps.
    """
    numbered = "\n\n".join(
        f"CANDIDATE {i}:\n{p}" for i, p in enumerate(profiles)
    )
    prompt = f"""
You are evaluating candidates for the following role:

JOB DESCRIPTION:
{job_description}

CANDIDATES:
{numbered}

For each candidate return a JSON object inside a "results" array with these keys:
  candidate_index (int), score (0-100 int), summary (str, ≤60 words),
  strengths (list of str), gaps (list of str).

Return ONLY valid JSON: {{"results": [...]}}
"""
    raw = await _chat(_RECRUITER_SYSTEM, prompt, json_mode=True)
    data = json.loads(raw)
    return data.get("results", [])


# ── 2. Resume Screening ────────────────────────────────────────────────────────

async def screen_resume(job_description: str, resume_text: str) -> dict:
    """
    Score a single resume against a job description.
    Returns: {score, feedback, recommended}
    """
    prompt = f"""
Evaluate this resume against the job description below.

JOB DESCRIPTION:
{job_description}

RESUME:
{resume_text}

Return ONLY valid JSON:
{{
  "score": <0-100>,
  "feedback": "<2-3 sentence summary of fit>",
  "recommended": <true|false>
}}
"""
    raw = await _chat(_RECRUITER_SYSTEM, prompt, json_mode=True)
    return json.loads(raw)


# ── 3. Job Description Generator ──────────────────────────────────────────────

async def generate_job_description(
    title: str,
    industry: str,
    location: str,
    key_responsibilities: str = "",
    required_skills: str = "",
    salary_range: str = "",
) -> str:
    """
    Generate a polished, inclusive job description for posting on the
    Building Materials Career job board.
    """
    prompt = f"""
Write a professional, inclusive job description for TalentHunt's job board.

Title: {title}
Industry: {industry}
Location: {location}
Key Responsibilities (hints): {key_responsibilities or 'not provided'}
Required Skills (hints): {required_skills or 'not provided'}
Salary Range: {salary_range or 'Competitive, commensurate with experience'}

Structure the JD with these sections:
  About the Role | Key Responsibilities | What You Bring |
  What We Offer | About TalentHunt

Keep it engaging, bias-free, and under 600 words.
Return ONLY the job description text (no JSON wrapper).
"""
    return await _chat(_RECRUITER_SYSTEM, prompt)


# ── 4. Interview Questions ─────────────────────────────────────────────────────

async def generate_interview_questions(
    job_title: str,
    industry: str,
    level: str,
    num_questions: int = 10,
) -> list[str]:
    """
    Generate role-specific, behaviour-based interview questions.
    """
    prompt = f"""
Generate {num_questions} interview questions for:
  Role: {job_title}
  Industry: {industry}
  Seniority: {level}

Mix behavioural (STAR-method), situational, and technical questions.
Return ONLY valid JSON: {{"questions": ["...", ...]}}
"""
    raw = await _chat(_RECRUITER_SYSTEM, prompt, json_mode=True)
    data = json.loads(raw)
    return data.get("questions", [])


# ── 5. Retention Chatbot (multi-turn) ─────────────────────────────────────────

async def retention_chat(history: list[dict], user_message: str) -> str:
    """
    Multi-turn retention / hiring advice chatbot.
    `history` is a list of {"role": "user"|"assistant", "content": "..."} dicts.
    """
    messages = [{"role": "system", "content": _RETENTION_SYSTEM}]
    messages.extend(history)
    messages.append({"role": "user", "content": user_message})

    response = await client.chat.completions.create(
        model=MODEL,
        messages=messages,
        temperature=0.6,
        max_tokens=600,
    )
    return response.choices[0].message.content.strip()
"""
Industries router – Building Materials, Life Sciences, Industrial,
Consumer Products, Technology.
"""

from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select

from app.database import get_db
from app.models import Industry
from app.schemas import IndustryCreate, IndustryOut

router = APIRouter()


@router.get("/", response_model=list[IndustryOut])
async def list_industries(db: AsyncSession = Depends(get_db)):
    result = await db.execute(select(Industry).order_by(Industry.name))
    return result.scalars().all()


@router.get("/{industry_id}", response_model=IndustryOut)
async def get_industry(industry_id: int, db: AsyncSession = Depends(get_db)):
    industry = await db.get(Industry, industry_id)
    if not industry:
        raise HTTPException(status_code=404, detail="Industry not found")
    return industry


@router.post("/", response_model=IndustryOut, status_code=201)
async def create_industry(payload: IndustryCreate, db: AsyncSession = Depends(get_db)):
    industry = Industry(**payload.model_dump())
    db.add(industry)
    await db.commit()
    await db.refresh(industry)
    return industry


@router.put("/{industry_id}", response_model=IndustryOut)
async def update_industry(
    industry_id: int,
    payload: IndustryCreate,
    db: AsyncSession = Depends(get_db),
):
    industry = await db.get(Industry, industry_id)
    if not industry:
        raise HTTPException(status_code=404, detail="Industry not found")
    for k, v in payload.model_dump().items():
        setattr(industry, k, v)
    await db.commit()
    await db.refresh(industry)
    return industry


@router.delete("/{industry_id}", status_code=204)
async def delete_industry(industry_id: int, db: AsyncSession = Depends(get_db)):
    industry = await db.get(Industry, industry_id)
    if not industry:
        raise HTTPException(status_code=404, detail="Industry not found")
    await db.delete(industry)
    await db.commit()

