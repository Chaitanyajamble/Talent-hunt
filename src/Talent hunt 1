"""
tests/test_selenium.py
──────────────────────


Requirements:
    pip install selenium webdriver-manager

Usage:
    # Chrome (default)
    selenium webdriver tests/test_selenium.py -v

    # Headless Chrome (CI)
    HEADLESS=1 pytest tests/test_selenium.py -v

    # Target a different base URL
    BASE_URL=https://staging.talenthunt.com pytest tests/test_selenium.py -v

Environment variables:
    BASE_URL      Root URL of the running app  (default: http://localhost:8000)
    HEADLESS      Set to any non-empty value to run Chrome headlessly
    OPENAI_API_KEY  Required only for LLM-dependent test cases
"""

import os
import time
from selenium import webdriver
from selenium.webdriver.chrome.options import Options as ChromeOptions
from selenium.webdriver.chrome.service import Service as ChromeService
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from webdriver_manager.chrome import ChromeDriverManager

# ── Configuration ──────────────────────────────────────────────────────────────

BASE_URL = os.getenv("BASE_URL", "http://localhost:8000")
HEADLESS = bool(os.getenv("HEADLESS", ""))
DEFAULT_WAIT = 10  # seconds


# ── Fixtures ───────────────────────────────────────────────────────────────────

def driver():
    """
    Create a single Chrome WebDriver instance shared across all tests in the
    session, then quit cleanly when the session ends.
    """
    options = ChromeOptions()
    if HEADLESS:
        options.add_argument("--headless=new")
    options.add_argument("--no-sandbox")
    options.add_argument("--disable-dev-shm-usage")
    options.add_argument("--window-size=1280,900")

    service = ChromeService(ChromeDriverManager().install())
    drv = webdriver.Chrome(service=service, options=options)
    drv.implicitly_wait(DEFAULT_WAIT)
    yield drv
    drv.quit()


def wait(driver):
    """Convenience fixture: explicit WebDriverWait bound to the shared driver."""
    return WebDriverWait(driver, DEFAULT_WAIT)


def navigate(driver, path: str):
    """Navigate to a path relative to BASE_URL."""
    driver.get(f"{BASE_URL}{path}")


def find(driver, by: By, value: str):
    """Find a single element with an implicit wait already applied."""
    return driver.find_element(by, value)


def find_all(driver, by: By, value: str):
    """Find all matching elements."""
    return driver.find_elements(by, value)


# ── Health check ───────────────────────────────────────────────────────────────

class TestHealth:
    """
    Original test: GET / → {"status": "ok"}

    Browser equivalent: load the root page and verify the page loads without
    a 404 / 500 error banner, and a recognisable brand element is present.
    """

    def test_home_page_loads(self, driver, wait):
        navigate(driver, "/")
        # The page title or a top-level heading should mention the brand.
        wait.until(EC.presence_of_element_located((By.TAG_NAME, "body")))
        assert "TalentHunt" in driver.title or driver.find_element(
            By.XPATH, "//*[contains(text(),'TalentHunt')]"
        )

    def test_no_server_error_on_home(self, driver):
        navigate(driver, "/")
        page_source = driver.page_source.lower()
        assert "500" not in page_source, "Server error detected on home page"
        assert "internal server error" not in page_source


# ── Leads — "Let's Talk" form ──────────────────────────────────────────────────

class TestLeads:
    """
    Original test: POST /leads/ with contact details → 201.

    Browser equivalent: fill in and submit the 'Let's Talk' contact form and
    verify the success state.
    """

    def test_submit_lead_form(self, driver, wait):
        navigate(driver, "/contact")  # Adjust path to match your routing

        # Fill in each field by its name / id / label
        driver.find_element(By.NAME, "full_name").send_keys("Jane Doe")
        driver.find_element(By.NAME, "email").send_keys("jane@example.com")
        driver.find_element(By.NAME, "phone").send_keys("555-0100")

        # Service dropdown
        from selenium.webdriver.support.ui import Select
        Select(driver.find_element(By.NAME, "service")).select_by_visible_text(
            "Contingency Recruitment"
        )

        driver.find_element(By.NAME, "message").send_keys(
            "We need to hire 5 engineers urgently."
        )

        # Submit
        driver.find_element(By.CSS_SELECTOR, "button[type='submit']").click()

        # Verify success message appears
        success = wait.until(
            EC.presence_of_element_located(
                (By.XPATH, "//*[contains(text(),'Thank you') or contains(text(),'received')]")
            )
        )
        assert success.is_displayed()

    def test_lead_form_validation_empty_submit(self, driver, wait):
        """Form should not submit when required fields are empty."""
        navigate(driver, "/contact")
        driver.find_element(By.CSS_SELECTOR, "button[type='submit']").click()

        # Either browser validation prevents navigation or an error message appears
        error_indicators = find_all(
            driver, By.CSS_SELECTOR, "[class*='error'], [class*='invalid'], :invalid"
        )
        assert len(error_indicators) > 0 or "contact" in driver.current_url.lower()


