# ── Retention Subscriber ───────────────────────────────────────────────────────

class TestRetention:
    """
    Original test: POST /retention/subscribe → 201; duplicate → 409.

    Browser equivalent: subscribe form submits successfully; re-submitting the
    same email shows a 'already subscribed' or duplicate message.
    """

    _email = f"alice.wong.selenium.{int(time.time())}@example.com"  # unique per run

    def test_retention_subscribe_success(self, driver, wait):
        navigate(driver, "/retention")  # Adjust path to your routing
        driver.find_element(By.NAME, "first_name").send_keys("Alice")
        driver.find_element(By.NAME, "last_name").send_keys("Wong")
        driver.find_element(By.NAME, "email").send_keys(self._email)
        driver.find_element(By.NAME, "company").send_keys("BuildCo")
        driver.find_element(By.CSS_SELECTOR, "button[type='submit']").click()

        success = wait.until(
            EC.presence_of_element_located(
                (By.XPATH, "//*[contains(text(),'subscribed') or contains(text(),'Thank you') or contains(text(),'success')]")
            )
        )
        assert success.is_displayed()

    def test_retention_duplicate_email_shows_error(self, driver, wait):
        navigate(driver, "/retention")
        driver.find_element(By.NAME, "first_name").send_keys("Alice")
        driver.find_element(By.NAME, "last_name").send_keys("Wong")
        driver.find_element(By.NAME, "email").send_keys(self._email)  # same email
        driver.find_element(By.NAME, "company").send_keys("BuildCo")
        driver.find_element(By.CSS_SELECTOR, "button[type='submit']").click()

        error = wait.until(
            EC.presence_of_element_located(
                (By.XPATH, "//*[contains(text(),'already') or contains(text(),'exists') or contains(text(),'duplicate')]")
            )
        )
        assert error.is_displayed()



