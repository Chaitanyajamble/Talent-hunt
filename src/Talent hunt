"""
app/routers/chat.py
───────────────────
AI-powered recruitment chatbot for site visitors.

Maintains conversation history per session so context carries across turns.
Typical use: a prospect visits talenthuntinc.com, asks about services,
industries served, or the hiring process.

Endpoints:
  POST /chat/         — send a message and receive a reply
  GET  /chat/{key}    — retrieve the full conversation history
  DELETE /chat/{key}  — clear / reset a session
"""

import json

from fastapi import APIRouter, Depends, HTTPException, status
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from app.database import get_db
from app.models import ChatSession
from app.schemas import ChatMessage, ChatRequest, ChatResponse
from app.services import llm

router = APIRouter(prefix="/chat", tags=["AI Chat — Recruitment Assistant"])


# ── Helper ────────────────────────────────────────────────────────────────────

def _load_history(session: ChatSession) -> list[dict]:
    """Deserialise the JSON-encoded message history stored in the DB row."""
    try:
        return json.loads(session.messages)
    except (json.JSONDecodeError, TypeError):
        return []


def _save_history(session: ChatSession, history: list[dict]) -> None:
    session.messages = json.dumps(history)


# ── Endpoints ─────────────────────────────────────────────────────────────────

@router.post("/", response_model=ChatResponse, status_code=status.HTTP_200_OK)
async def chat(payload: ChatRequest, db: AsyncSession = Depends(get_db)):
    """
    Send a message to TalentBot.

    The session_key is a UUID generated by the client and reused for every
    turn of the same conversation. If the key does not exist yet a new
    session is created automatically.
    """
    # Fetch or create the session row
    result = await db.execute(
        select(ChatSession).where(ChatSession.session_key == payload.session_key)
    )
    session = result.scalar_one_or_none()

    if session is None:
        session = ChatSession(session_key=payload.session_key, messages="[]")
        db.add(session)
        await db.flush()  # get the id without committing

    # Append the user's message to history
    history = _load_history(session)
    history.append({"role": "user", "content": payload.message})

    # Call Claude with the full conversation history
    reply = llm.recruitment_chat(history)

    # Append the assistant reply and persist
    history.append({"role": "assistant", "content": reply})
    _save_history(session, history)
    await db.commit()

    return ChatResponse(
        session_key=payload.session_key,
        reply=reply,
        history=[ChatMessage(**m) for m in history],
    )


@router.get("/{session_key}", response_model=ChatResponse)
async def get_history(session_key: str, db: AsyncSession = Depends(get_db)):
    """Retrieve the full conversation history for a session."""
    result = await db.execute(
        select(ChatSession).where(ChatSession.session_key == session_key)
    )
    session = result.scalar_one_or_none()
    if not session:
        raise HTTPException(status_code=404, detail="Session not found")

    history = _load_history(session)
    return ChatResponse(
        session_key=session_key,
        reply="",
        history=[ChatMessage(**m) for m in history],
    )


@router.delete("/{session_key}", status_code=status.HTTP_204_NO_CONTENT)
async def clear_session(session_key: str, db: AsyncSession = Depends(get_db)):
    """Reset a chat session (clear all messages)."""
    result = await db.execute(
        select(ChatSession).where(ChatSession.session_key == session_key)
    )
    session = result.scalar_one_or_none()
    if not session:
        raise HTTPException(status_code=404, detail="Session not found")

    session.messages = "[]"
    await db.commit()
