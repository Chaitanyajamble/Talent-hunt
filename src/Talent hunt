    fit_summary = Column(Text)              # LLM narrative summary
    strengths = Column(Text)                # JSON list stored as text
    gaps = Column(Text)                     # JSON list stored as text
    interview_questions = Column(Text)      # JSON list of suggested questions
    recommendation = Column(String(50))     # "Strongly Recommend" etc.
    created_at = Column(DateTime(timezone=True), server_default=func.now())

    candidate = relationship("Candidate", back_populates="assessments")
    application = relationship("Application", back_populates="assessments")


# ──────────────────────────────────────────────
# Review — Client testimonials carousel
# ──────────────────────────────────────────────

class Review(Base):
    __tablename__ = "reviews"

    id = Column(Integer, primary_key=True, index=True)
