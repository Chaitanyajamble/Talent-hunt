    company = Column(String(200))
    checklist_sent = Column(Integer, default=0)
    created_at = Column(DateTime(timezone=True), server_default=func.now())


# ──────────────────────────────────────────────
# ChatSession — AI Chatbot threads
# ──────────────────────────────────────────────

class ChatSession(Base):
