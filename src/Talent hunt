import enum
from datetime import datetime

from sqlalchemy import (
    Column, DateTime, Enum, Float, ForeignKey,
    Integer, String, Text,
)
from sqlalchemy.orm import relationship
from sqlalchemy.sql import func

from app.database import Base


# ──────────────────────────────────────────────
# Enums
# ──────────────────────────────────────────────

class ServiceType(str, enum.Enum):
    MEMBERSHIP = "Membership Program"
    CONTINGENCY = "Contingency Recruitment"
    RPO = "Recruitment Process Solutions"
    RETAIN_REFUND = "Retain or Refund"
    DIGITAL = "Digital Transformation"


class IndustryType(str, enum.Enum):
    BUILDING_MATERIALS = "Building Materials"
    LIFE_SCIENCES = "Life Sciences / Medical"
    INDUSTRIAL = "Industrial / Manufacturing"
    CONSUMER = "Consumer Products"
    TECHNOLOGY = "Technology"


class RecruitmentStep(str, enum.Enum):
    HUNT = "HUNT"
    ASSESS = "ASSESS"
    MANAGE = "MANAGE"
    GROW = "GROW"


class ApplicationStatus(str, enum.Enum):
    APPLIED = "Applied"
    HUNTING = "Hunting"       # Step 1 — sourced
    ASSESSED = "Assessed"     # Step 2 — evaluation done
    MANAGED = "Managed"       # Step 3 — interview / offer managed
    PLACED = "Placed"         # Step 4 — hired & growing
    REJECTED = "Rejected"


# ──────────────────────────────────────────────
# Lead — "Let's Talk" contact form
# ──────────────────────────────────────────────

class Lead(Base):
    __tablename__ = "leads"

    id = Column(Integer, primary_key=True, index=True)
    full_name = Column(String(120), nullable=False)
    email = Column(String(200), nullable=False, index=True)
    phone = Column(String(30))
    service = Column(Enum(ServiceType), nullable=False)
    message = Column(Text)
    created_at = Column(DateTime(timezone=True), server_default=func.now())


# ──────────────────────────────────────────────
# Job — Job Board listings
# ──────────────────────────────────────────────

class Job(Base):
    __tablename__ = "jobs"

    id = Column(Integer, primary_key=True, index=True)
    title = Column(String(200), nullable=False)
    company = Column(String(200))
    location = Column(String(200))
    industry = Column(Enum(IndustryType), nullable=False)
    description = Column(Text, nullable=False)
    requirements = Column(Text)
    salary_range = Column(String(100))
    is_active = Column(Integer, default=1)   # 1 = open, 0 = filled
    created_at = Column(DateTime(timezone=True), server_default=func.now())

    applications = relationship("Application", back_populates="job")


# ──────────────────────────────────────────────
# Candidate — Job Seekers
# ──────────────────────────────────────────────

class Candidate(Base):
    __tablename__ = "candidates"

    id = Column(Integer, primary_key=True, index=True)
    full_name = Column(String(120), nullable=False)
    email = Column(String(200), nullable=False, unique=True, index=True)
    phone = Column(String(30))
    industry = Column(Enum(IndustryType))
    resume_text = Column(Text)            # plain-text resume for LLM processing
    linkedin_url = Column(String(300))
    created_at = Column(DateTime(timezone=True), server_default=func.now())

    applications = relationship("Application", back_populates="candidate")
