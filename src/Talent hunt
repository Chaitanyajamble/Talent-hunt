"""
app/services/llm.py
───────────────────
Central wrapper around the OpenAI API.

All LLM-powered features route through this module:
  1. assess_candidate()     — ASSESS step: score resume vs job description
  2. generate_retention_checklist() — Retention Checklist popup
  3. recruitment_chat()     — AI chatbot for site visitors
  4. suggest_interview_questions() — GROW step: tailored interview Q&A
"""

import json
import re
from typing import Optional

import OpenAI

from app.config import get_settings

settings = get_settings()

# One shared client; the API key is picked up from the environment.
_client = OpenAI.OpenAI(api_key=settings.OpenAI_api_key)

# ── Shared system prompts ────────────────────────────────────────────────────

_TALENTHUNT_PERSONA = """
You are TalentBot, an expert AI recruitment assistant f. —


TalentHunt's 4-step process:
  1. HUNT   — Source and attract top talent.
  2. ASSESS — Evaluate candidates with neuroscience-backed tools.
  3. MANAGE — Guide both client and candidate through the hiring campaign.
  4. GROW   — Turn new hires into long-term high performers.

Services: Contingency Recruitment, Recruitment Process Solutions (RPO),
Digital Transformation, and the Retain-or-Refund Guarantee.

Be concise, professional, and warm. Focus on the client's hiring or
retention goals. Never give medical or legal advice.
""".strip()


# ── 1. Candidate Assessment ──────────────────────────────────────────────────

def assess_candidate(
    candidate_name: str,
    resume_text: str,
    job_title: str,
    job_description: str,
    industry: str,
) -> dict:
    """
    Use Claude to evaluate a candidate's resume against a job description.

    Returns a structured dict with:
      - overall_score (float 0-10)
      - fit_summary   (narrative string)
      - strengths     (list[str])
      - gaps          (list[str])
      - interview_questions (list[str])
      - recommendation (str)
    """
    prompt = f"""
You are assessing a candidate for TalentHunt Inc.

## Candidate
Name: {candidate_name}
Industry: {industry}

## Resume
{resume_text or "No resume provided."}

## Job
Title: {job_title}
Description:
{job_description or "No description provided."}

## Your Task
Evaluate fit and respond ONLY with a valid JSON object (no markdown, no extra text):

{{
  "overall_score": <float 0.0-10.0>,
  "fit_summary": "<2-3 sentence narrative>",
  "strengths": ["<strength 1>", "<strength 2>", ...],
  "gaps": ["<gap 1>", "<gap 2>", ...],
  "interview_questions": ["<question 1>", "<question 2>", "<question 3>"],
  "recommendation": "<Strongly Recommend | Recommend | Neutral | Not Recommended>"
}}
""".strip()

    response = _client.messages.create(
        model=settings.OpenAI_model,
        max_tokens=1024,
        system=_TALENTHUNT_PERSONA,
        messages=[{"role": "user", "content": prompt}],
    )

    raw = response.content[0].text.strip()
    # Strip any accidental markdown fences
    raw = re.sub(r"^```(?:json)?|```$", "", raw, flags=re.MULTILINE).strip()
    return json.loads(raw)


# ── 2. Retention Checklist Generator ────────────────────────────────────────

def generate_retention_checklist(
    company_size: Optional[str] = None,
    industry: Optional[str] = None,
    pain_points: Optional[str] = None,
) -> dict:
    """
    Generate a personalised employee-retention checklist.

    Returns:
      - checklist: list[str]   — actionable items
      - summary:  str          — brief intro paragraph
    """
    context_parts = []
    if company_size:
        context_parts.append(f"Company size: {company_size}")
    if industry:
        context_parts.append(f"Industry: {industry}")
    if pain_points:
        context_parts.append(f"Current pain points: {pain_points}")

    context = "\n".join(context_parts) if context_parts else "No specific context provided."

    prompt = f"""
You are a retention specialist at TalentHunt Inc.

Context about the requesting company:
{context}

Generate a practical employee retention checklist tailored to the context above.
Respond ONLY with a valid JSON object (no markdown, no extra text):

{{
  "summary": "<2-3 sentence intro about why retention matters for this company>",
  "checklist": [
    "<actionable item 1>",
    "<actionable item 2>",
    ...
  ]
}}

Include 8-12 specific, actionable checklist items.
""".strip()

    response = _client.messages.create(
        model=settings.OpenAI_model,
        max_tokens=1024,
        system=_TALENTHUNT_PERSONA,
        messages=[{"role": "user", "content": prompt}],
    )

    raw = response.content[0].text.strip()
    raw = re.sub(r"^```(?:json)?|```$", "", raw, flags=re.MULTILINE).strip()
    return json.loads(raw)


# ── 3. AI Recruitment Chatbot ────────────────────────────────────────────────

def recruitment_chat(history: list[dict]) -> str:
    """
    Continue a multi-turn conversation with the TalentHunt AI chatbot.

    `history` is a list of {"role": "user"|"assistant", "content": str} dicts
    representing the full conversation so far (latest message last).

    Returns the assistant's next reply as a plain string.
    """
    response = _client.messages.create(
        model=settings.OpenAI_model,
        max_tokens=512,
        system=_TALENTHUNT_PERSONA,
        messages=history,
    )
    return response.content[0].text.strip()


# ── 4. Interview Question Suggester ─────────────────────────────────────────

def suggest_interview_questions(
    job_title: str,
    job_description: str,
    candidate_summary: str,
    industry: str,
) -> list[str]:
    """
    GROW step: generate targeted behavioural and technical interview questions
    based on the role and candidate profile.

    Returns a list of question strings.
    """
    prompt = f"""
Generate tailored interview questions for a hiring manager at TalentHunt Inc.

Role: {job_title}
Industry: {industry}
Job Description:
{job_description}

Candidate Summary:
{candidate_summary}

Provide 5 behavioural questions and 3 role-specific technical questions.
Respond ONLY with a JSON array of strings (no markdown, no extra text):

["<question 1>", "<question 2>", ...]
""".strip()

    response = _client.messages.create(
        model=settings.OpenAI_model,
        max_tokens=800,
        system=_TALENTHUNT_PERSONA,
        messages=[{"role": "user", "content": prompt}],
    )

    raw = response.content[0].text.strip()
    raw = re.sub(r"^```(?:json)?|```$", "", raw, flags=re.MULTILINE).strip()
    return json.loads(raw)
"""
app/routers/recruitment.py
──────────────────────────
Implements TalentHunt's 4-Step Recruitment Process:

  1. HUNT   — Register a candidate against a role
  2. ASSESS — Trigger an LLM evaluation of the candidate
  3. MANAGE — Update the campaign step / recruiter notes
  4. GROW   — Generate tailored interview questions for onboarding

Endpoints:
  POST /recruitment/candidates/              — register a candidate (HUNT)
  GET  /recruitment/candidates/              — list candidates
  GET  /recruitment/candidates/{id}          — get candidate detail
  POST /recruitment/applications/            — apply candidate to a job
  GET  /recruitment/applications/            — list applications
  GET  /recruitment/applications/{id}        — get application detail
  POST /recruitment/applications/{id}/assess — run LLM assessment (ASSESS)
  PUT  /recruitment/applications/{id}/step   — advance campaign step (MANAGE)
  GET  /recruitment/applications/{id}/grow   — get interview questions (GROW)
"""

import json

from fastapi import APIRouter, Depends, HTTPException, status
from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from app.database import get_db
from app.models import Application, Assessment, Candidate, Job, RecruitmentStep
from app.schemas import (
    ApplicationCreate,
    ApplicationResponse,
    ApplicationStepUpdate,
    AssessmentRequest,
    AssessmentResponse,
    CandidateCreate,
    CandidateResponse,
)
from app.services import llm

router = APIRouter(prefix="/recruitment", tags=["Recruitment — 4-Step Process"])


# ── HUNT: Candidate Registration ─────────────────────────────────────────────

@router.post(
    "/candidates/",
    response_model=CandidateResponse,
    status_code=status.HTTP_201_CREATED,
    summary="HUNT — Register a new candidate",
)
async def register_candidate(
    payload: CandidateCreate, db: AsyncSession = Depends(get_db)
):
    """
    Step 1 — HUNT.
    Add a candidate to the talent pool. Accepts a plain-text resume for
    later LLM assessment.
    """
    candidate = Candidate(**payload.model_dump())
    db.add(candidate)
    await db.commit()
    await db.refresh(candidate)
    return candidate


@router.get("/candidates/", response_model=list[CandidateResponse])
async def list_candidates(
    skip: int = 0, limit: int = 20, db: AsyncSession = Depends(get_db)
):
    """List all candidates in the talent pool."""
    result = await db.execute(select(Candidate).offset(skip).limit(limit))
    return result.scalars().all()


@router.get("/candidates/{candidate_id}", response_model=CandidateResponse)
async def get_candidate(candidate_id: int, db: AsyncSession = Depends(get_db)):
    """Get a single candidate's profile."""
    candidate = await db.get(Candidate, candidate_id)
    if not candidate:
        raise HTTPException(status_code=404, detail="Candidate not found")
    return candidate


# ── Apply candidate to a job ──────────────────────────────────────────────────

@router.post(
    "/applications/",
    response_model=ApplicationResponse,
    status_code=status.HTTP_201_CREATED,
    summary="Apply a candidate to a job opening",
)
async def create_application(
    payload: ApplicationCreate, db: AsyncSession = Depends(get_db)
):
    """
    Link a candidate to a job posting.
    The application starts in HUNT step.
    """
    candidate = await db.get(Candidate, payload.candidate_id)
    if not candidate:
        raise HTTPException(status_code=404, detail="Candidate not found")

    job = await db.get(Job, payload.job_id)
    if not job:
